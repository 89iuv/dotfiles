{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "permission": {
    "webfetch": "ask",
    "context7*": "ask",
  },
  "enabled_providers": ["ollama-private"],
  "provider": {
    "ollama-private": {
      "name": "Ollama (private)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "{env:OLLAMA_WEB_URL}/v1",
        "headers": {
          "Authorization": "Bearer {env:OLLAMA_API_KEY}"
        }
      },
      "models": {
        "gpt-oss:20b": {
          "name": "gpt-oss:20b"
        },
        "qwen3.5:9b": {
          "name": "qwen3.5:9b"
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}"
      ],
      "enabled": true
    }
  }
}
