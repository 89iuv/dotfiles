{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "run",
  "permission": {
    "webfetch": "deny",
    "websearch": "deny"
  },
  "agent": {
    "run": {
      "mode": "primary",
      "description": "A multi purpose AI agent.",
      "prompt": "You are a versatile AI assistant. Handle coding, writing, research, troubleshooting, and anything else asked. Dive deep when needed but keep answers concise.",
      "color": "warning",
      "permission": {
        "*": "deny",
        "bash": "allow",
        "edit": "allow",
        "read": "allow",
        "glob": "allow",
        "list": "allow",
        "context7_*": "allow",
        "playwright_*": "allow"
      }
    }
  },
  "enabled_providers": ["zcat_llm"],
  "provider": {
    "zcat_llm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Zcat LLM",
      "options": {
        "baseURL": "https://zcat.go.ro/v1",
        "apiKey": "{env:ZCAT_LLM_KEY}"
      },
      "models": {
        "openai/gpt-oss-20b": {
          "name": "openai/gpt-oss-20b",
          "variants": {
            "high": {
              "reasoningEffort": "high"
            },
            "low": {
              "reasoningEffort": "low"
            }
          }
        },
        "qwen/qwen3.5-9b": {
          "name": "qwen/qwen3.5-9b"
        },
        "qwen/qwen3.5-35b-a3b": {
          "name": "qwen/qwen3.5-35b-a3b"
        },
        "google/gemma-4-26b-a4b": {
          "name": "google/gemma-4-26b-a4b"
        },
        "google/gemma-4-e4b": {
          "name": "google/gemma-4-e4b"
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx", 
        "@playwright/mcp@latest", 
        "--isolated", 
        "--sandbox"
      ],
      "enabled": true
    }
  }
}
