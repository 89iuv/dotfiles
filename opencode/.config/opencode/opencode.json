{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "run",
  "permission": {
    "webfetch": "deny",
    "websearch": "deny"
  },
  "agent": {
    "title": {
      "disable": false,
      "options": {
        "reasoningEffort": "none"
      }
    }
  },
  
  "provider": {
    "zcat_llm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Zcat LLM",
      "options": {
        "baseURL": "https://zcat.go.ro/v1",
        "apiKey": "{env:ZCAT_LLM_KEY}"
      },
      "models": {
        "openai/gpt-oss-20b": {
          "name": "openai/gpt-oss-20b",
          "limit": {
            "context": 49152,
            "output": 8192
          },
          "variants": {
            "high": {
              "reasoningEffort": "high"
            },
            "low": {
              "reasoningEffort": "low"
            }
          }
        },
        "qwen/qwen3.6-35b-a3b": {
          "name": "qwen/qwen3.6-35b-a3b",
          "limit": {
            "context": 98304,
            "output": 32768
          }
        },
      }
    }
  }
}
