{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "question",
  "permission": {
    "webfetch": "deny",
    "context7*": "ask",
    "playwright": "ask"
  },
  "agent": {
    "question": {
      "mode": "primary",
      "description": "Answers user questions.",
      "prompt": "Provide a short and concise answer.",
      "color": "warning",
      "permission": {
        "*": "deny",
        "bash": "allow",
        "read": "allow",
        "edit": "allow",
        "context7": "ask",
        "playwright": "ask"
      }
    }
  },
  "enabled_providers": ["zcat_llm"],
  "provider": {
    "zcat_llm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Zcat LLM",
      "options": {
        "baseURL": "https://zcat.go.ro/v1",
        "apiKey": "{env:ZCAT_LLM_KEY}"
      },
      "models": {
        "openai/gpt-oss-20b": {
          "name": "openai/gpt-oss-20b",
          "variants": {
            "high":{
              "reasoningEffort": "high"
            },
            "low":{
              "reasoningEffort": "low"
            }
          }
        },
        "qwen/qwen3.5-9b": {
          "name": "qwen/qwen3.5-9b"
        },
        "qwen/qwen3.5-35b-a3b": {
          "name": "qwen/qwen3.5-35b-a3b"
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest",
      ],
      "enabled": true
    }
  }
}
